# === Unified security + performance baseline (network-wide parity) ===
# Content-Security-Policy is deployed in Report-Only mode first: it captures violations
# without blocking any revenue-critical payload, so lead-gen uptime is unaffected while
# the allowlist is validated against real traffic. Keeps 'unsafe-inline' so existing
# inline scripts/styles keep working. This site loads no external scripts/styles/iframes
# beyond Bing UET (bat.bing.com), so the allowlist is minimal. bat.js is a mutable vendor
# script, so SRI is intentionally not pinned. Once violation reports are clean, rename the
# header to Content-Security-Policy to enforce.
/*
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-inline' https://bat.bing.com; connect-src 'self' https://bat.bing.com; form-action 'self'; report-uri /api/mesh/015-telemetry-collector/csp-report; report-to csp-endpoint; upgrade-insecure-requests
  Reporting-Endpoints: csp-endpoint="https://debtreliefguard.com/api/mesh/015-telemetry-collector/csp-report"
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Cache-Control: public, max-age=0, must-revalidate

# Blog JSON list and shell HTML should never be cached between requests
/blogs.json
  Cache-Control: no-store, must-revalidate
  Content-Type: application/json; charset=utf-8
  Vary: Accept, Origin
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: *

/blog.index.html
  Cache-Control: no-cache, must-revalidate

# All generated blog HTML should be publicly cacheable but CORS-accessible
/blog/*.html
  Cache-Control: public, max-age=600
  Vary: Accept, Origin
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: *

# Blog folder (covers generated HTML + assets in /blog)
/blog/*
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: *

/content/blog/*
  Cache-Control: public, max-age=300

# Home and other HTML can also be no-cache if you prefer dynamic updates
/index.html
  Cache-Control: no-cache, must-revalidate
  Vary: Accept, Origin

# Static assets — cache hard for 1 year with immutable
/images/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable
